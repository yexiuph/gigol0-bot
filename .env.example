# --- Discord Configuration ---
# Your Bot Token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# --- Branding & Resources ---
# The footer text displayed at the bottom right of the quote card
QUOTE_FOOTER="discord.gg/yourlink | © Your System Name"

# Path to the folder containing font.ttf and logo.png
RESOURCE_DIR="resources"

# --- AI Configuration (Optional/Legacy) ---
# AI API Key for other bot features
AI_API_KEY=your_ai_api_key_here
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
AI_MAX_TOKENS=100

# --- Database ---
DATABASE_URL=sqlite:database.db
